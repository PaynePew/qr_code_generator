# Copy to .env.prod (gitignored) and fill in. NEVER commit real secrets.
# Consumed by docker-compose.prod.yml (qrcode-app, qrcode-migrate, qrcode-db).

# --- App ---
SECRET=change-me-to-a-long-random-secret
BASE_URL=https://qrcode.paynepew.dev
# App + alembic talk to the in-project Postgres by SERVICE NAME (not localhost).
# The password here MUST match POSTGRES_PASSWORD below.
DATABASE_URL=postgresql://qrcode:change-me@qrcode-db:5432/qr_codes

# --- Postgres (consumed by the qrcode-db service) ---
POSTGRES_USER=qrcode
POSTGRES_PASSWORD=change-me
POSTGRES_DB=qr_codes

# --- Auth / session (ADR 0009) ---
GOOGLE_CLIENT_ID=                  # add the prod origin + redirect URI to this OAuth client
SESSION_COOKIE_SECURE=true         # prod is HTTPS behind the edge
SESSION_MAX_AGE=1209600

# --- Behind the edge Caddy reverse proxy ---
# 1 trusted proxy hop, so X-Forwarded-For is read correctly. If left at 0, every
# request looks like it comes from the proxy IP → one shared rate-limit bucket →
# the whole site 429s. MUST be 1 in this topology.
TRUSTED_PROXIES=1

# --- Rate limiting (ADR 0007 + 0009) ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_HOURLY=30
RATE_LIMIT_DAILY=200
AUTH_RATE_LIMIT_HOURLY=10
AUTH_RATE_LIMIT_DAILY=40

# --- AWS S3 (customized-QR storage, ADR 0011) — bucket already provisioned ---
AWS_S3_BUCKET=qrgen-customized-prod
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- CDN (CloudFront + OAC, ADR 0017, bd ebf) ---
# CloudFront distribution fronting qrgen-customized-prod (bucket is private, OAC-only).
# storage.url_for returns CloudFront image URLs when set; empty = direct S3 fallback.
CDN_BASE_URL=https://d19ccr5zg4lhn9.cloudfront.net

# --- GeoLite2 City DB (ADR 0016, bd bii) ---
# Provides country + subdivision (region). The container must have GeoLite2-City.mmdb at
# this path — bake it into the image or mount a volume that a weekly `geoipupdate` cron
# refreshes (GeoLite2's EULA requires staying current). Empty = no geo derivation.
GEOIP_DB_PATH=/usr/share/GeoIP/GeoLite2-City.mmdb

# CORS: not needed in prod (same-origin behind the edge). The localhost-only
# regex in main.py won't match the prod origin, so it's inert — qrcode may drop
# the CORSMiddleware entirely for prod.
