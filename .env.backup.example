# Backup-only AWS credentials for the nightly Postgres -> S3 job.
#
# These are the LEAST-PRIVILEGE, backup-only IAM user credentials: scoped to
# PutObject (plus Get and List) on the s3://qrgen-customized-prod/backups/qrcode
# prefix ONLY. They are SEPARATE from the app's AWS keys in .env.prod (which
# serve the customized-QR storage feature) — do not reuse one for the other.
#
# Owner places this ONCE: copy to /opt/qrcode/.env.backup with mode 600
# (chmod 600 /opt/qrcode/.env.backup). It is read by qrcode-backup.service via
# EnvironmentFile and must NEVER be committed. CD never touches this file.

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-northeast-1
