SECRET=change-me-to-a-long-random-secret
BASE_URL=http://localhost:8000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/qr_codes

# Google OAuth client id for ID-token verification (from the provisioning slice).
GOOGLE_CLIENT_ID=

# Session cookie (ADR 0009). Set SESSION_COOKIE_SECURE=false only for local HTTP
# dev; production must serve over HTTPS with it true. SESSION_MAX_AGE is seconds.
SESSION_COOKIE_SECURE=true
SESSION_MAX_AGE=1209600

# Rate limiting (ADR 0007 + 0009). RATE_LIMIT_ENABLED is the master kill-switch.
# RATE_LIMIT_* is the per-USER create quota (login required to create, so it is
# keyed by account). AUTH_RATE_LIMIT_* is the per-IP cap on POST /api/auth/session
# that guards against account-farming. Both enforce hourly AND daily windows
# (daily >= hourly). TRUSTED_PROXIES is the number of trusted reverse-proxy hops
# in X-Forwarded-For (0 = use the socket peer; behind one proxy in prod, set 1).
RATE_LIMIT_ENABLED=true
RATE_LIMIT_HOURLY=30
RATE_LIMIT_DAILY=200
AUTH_RATE_LIMIT_HOURLY=10
AUTH_RATE_LIMIT_DAILY=40
TRUSTED_PROXIES=0

# AWS S3 (customized-QR storage, ADR 0011). Leave AWS_S3_BUCKET empty to use the
# on-disk LocalDiskGateway (no AWS needed — the local-dev default; customized QR
# images + logos persist across restarts under backend/data/storage). Set bucket
# + region to enable S3. Credentials use boto3's default chain (the vars below, or
# an IAM role). AWS_ENDPOINT_URL is optional — set it only for MinIO / LocalStack.
AWS_S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL=
# Optional: override where LocalDiskGateway writes (defaults to backend/data/storage).
LOCAL_STORAGE_DIR=

# GeoLite2 City DB (ADR 0016, bd bii). Absolute path to GeoLite2-City.mmdb, read once at
# startup to derive a coarse country + subdivision (region) from the scanner IP at ingest
# (city / lat-long / the raw IP are discarded — never persisted). Leave empty to skip geo
# derivation (country = subdivision = None). Download the .mmdb into backend/data/ (see
# backend/data/README.md) and point this at it, e.g. on Windows:
# GEOIP_DB_PATH=C:\Users\MaxL\work\projects\live_sessions\qr_code_generator\backend\data\GeoLite2-City.mmdb
GEOIP_DB_PATH=
