# Agent harness configuration — copy to config.yml and edit if needed.
#
# This file is the project-specific starting point for qr_code_generator.
# After copying:
#   - Adjust agent models / turn budgets if you want.
#   - Drop in the right CLAUDE_CODE_OAUTH_TOKEN in .env.local (separate file).

image: agent-harness:latest

# Branch naming convention: {prefix}{N}-{slug-from-issue-title}
branch_prefix: kanban-issue

tracker:
  type: github
  repo: PaynePew/bbqrcode-generator

defaults:
  model: claude-sonnet-4-6

agents:
  implement:
    model: claude-sonnet-4-6
    max_turns: 80
  plan:
    model: claude-opus-4-7
    max_turns: 10
  review:
    model: claude-opus-4-7
    max_turns: 30
  # Merge is mechanical (rebase, conflict resolution, push) — haiku is enough.
  merge:
    model: claude-haiku-4-5
    max_turns: 30

# All design + decision docs live under `docs/` (plural). The singular
# `doc/` tree is legacy course material (grilling sessions, study notes)
# and is not referenced by the harness.
docs:
  prd_dir: docs/PRD
  context: CONTEXT.md
  adr_dir: docs/adr

# Test gate runs before merge. Backend uses pytest (SQLite — no compose
# stack); frontend uses Vitest.
tests:
  block: pytest tests/ && npm test --prefix frontend

# Frontend TypeScript typecheck (tsc --noEmit via npm script).
typecheck:
  block: npm run typecheck --prefix frontend

commit:
  style: Conventional Commits (feat/fix/test/docs/chore/refactor/perf/ci). One logical change per commit. Reference the GitHub issue (Refs #N or Closes #N).
