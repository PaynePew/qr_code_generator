# E2E (bead 8vd) runs the SPA SAME-ORIGIN through the Vite proxy, not the
# cross-origin VITE_API_BASE_URL dev config — so the httpOnly session cookie
# isn't subject to CORS and behaves like prod (SPA + API share an origin).
# Vite skips .env.local in `test` mode, so an empty value here cleanly overrides
# the dev `VITE_API_BASE_URL=http://localhost:8000`.
VITE_API_BASE_URL=
