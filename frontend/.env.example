# Axios base URL. Leave EMPTY in dev so requests stay same-origin and ride the
# Vite proxy (ADR 0009) — the session cookie only flows same-origin.
VITE_API_BASE_URL=

# Google OAuth client id for One Tap / Sign-in-with-Google (ADR 0009).
VITE_GOOGLE_CLIENT_ID=

# Dev-only: where the Vite proxy forwards /api and /r. Defaults to the backend's
# local BASE_URL; override if the backend runs elsewhere.
API_PROXY_TARGET=http://localhost:8000
